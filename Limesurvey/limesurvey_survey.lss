    <language><![CDATA[de]]></language>
   </row>
   <row>
    <id><![CDATA[1226658]]></id>
    <qid><![CDATA[1731445]]></qid>
    <question><![CDATA[I learn from mistakes so that I can avoid them in future projects. ]]></question>
    <help/>
    <language><![CDATA[en]]></language>
