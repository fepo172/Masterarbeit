   <row>
    <id><![CDATA[1226628]]></id>
    <qid><![CDATA[1731431]]></qid>
    <question><![CDATA[I recognize familiar algorithmic patterns or design patterns and thus quickly grasp the higher semantic meaning of the code.]]></question>
