   <row>
    <id><![CDATA[1226627]]></id>
    <qid><![CDATA[1731431]]></qid>
    <question><![CDATA[Ich erkenne bekannte algorithmische Muster oder Entwurfsmuster und erfasse dadurch schnell die höhere semantische Bedeutung des Codes.]]></question>
    <help/>
