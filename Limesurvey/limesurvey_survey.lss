   <row>
    <id><![CDATA[1226625]]></id>
    <qid><![CDATA[1731430]]></qid>
    <question><![CDATA[Um Code zu verstehen oder einen Einstiegspunkt zu finden, interagiere ich zunächst mit der Benutzeroberfläche (UI) des Programms.]]></question>
