   <row>
    <id><![CDATA[1226659]]></id>
    <qid><![CDATA[1731446]]></qid>
    <question><![CDATA[Ich nutze Techniken wie zum Beispiel Program Slicing, um die Menge an zu untersuchendem Code auf die fehlerrelevanten Teile zu reduzieren.]]></question>
    <help/>
    <language><![CDATA[de]]></language>
