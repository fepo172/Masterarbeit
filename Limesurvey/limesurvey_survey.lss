   <row>
    <id><![CDATA[1226631]]></id>
    <qid><![CDATA[1731433]]></qid>
    <question><![CDATA[ Wenn ich bei einem Problem nicht weiterkomme, suche ich gezielt die Interaktion mit Kollegen oder Online-Communities.]]></question>
